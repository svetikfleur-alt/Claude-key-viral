{
  "comfyui_url": "http://127.0.0.1:8188",
  "comfyui_input_dir": "C:/path/to/ComfyUI/input",
  "comfyui_output_dir": "C:/path/to/ComfyUI/output",
  "workflows_dir": "./workflows",
  "logs_dir": "./logs",
  "generated_media_dir": "./generated-media",
  "outputs_index_file": "./logs/output-index.json",
  "request_timeout_seconds": 30,
  "polling_interval_seconds": 2,
  "polling_timeout_seconds": 300,
  "workflows": {
    "passthrough-image": {
      "file": "passthrough-image.workflow.json",
      "description": "Minimal end-to-end wiring test: LoadImage -> SaveImage. No models required. Uses robot-source.png from ComfyUI input/.",
      "comfyui_url_override": "http://127.0.0.1:8000",
      "mappings": {
        "extra_params": {
          "filename_prefix": { "node_id": "2", "field_path": ["inputs", "filename_prefix"] }
        }
      }
    },
    "passthrough-any-image": {
      "file": "passthrough-any-image.workflow.json",
      "description": "ComfyUI background stage: LoadImage -> SaveImage with an overridable filename. No models required.",
      "comfyui_url_override": "http://127.0.0.1:8000",
      "mappings": {
        "extra_params": {
          "source_image": { "node_id": "1", "field_path": ["inputs", "image"] },
          "filename_prefix": { "node_id": "2", "field_path": ["inputs", "filename_prefix"] }
        }
      }
    },
    "basic-image": {
      "file": "basic-image.workflow.json",
      "description": "Simple passthrough workflow for testing. Loads input image and saves it. No model required.",
      "mappings": {
        "extra_params": {
          "source_image": { "node_id": "1", "field_path": ["inputs", "image"] }
        }
      }
    },
    "qwen-image-edit-pro": {
      "file": "qwen-image-edit-pro.workflow.json",
      "description": "Local Qwen Image Edit workflow (photoreal-ish edits). Defaults to ComfyUI Desktop-safe on :8000.",
      "comfyui_url_override": "http://127.0.0.1:8000",
      "default_inputs": {
        "extra_params": {
          "steps": 4,
          "cfg": 1,
          "denoise": 0.78,
          "source_image": "robot-source.png"
        }
      },
      "mappings": {
        "positive_prompt": {
          "node_id": "6",
          "field_path": ["inputs", "prompt"]
        },
        "seed": {
          "node_id": "9",
          "field_path": ["inputs", "seed"]
        },
        "extra_params": {
          "steps": {
            "node_id": "9",
            "field_path": ["inputs", "steps"]
          },
          "cfg": {
            "node_id": "9",
            "field_path": ["inputs", "cfg"]
          },
          "denoise": {
            "node_id": "9",
            "field_path": ["inputs", "denoise"]
          },
          "clip_device": {
            "node_id": "3",
            "field_path": ["inputs", "device"]
          },
          "filename_prefix": {
            "node_id": "11",
            "field_path": ["inputs", "filename_prefix"]
          },
          "source_image": {
            "node_id": "1",
            "field_path": ["inputs", "image"]
          }
        }
      }
    },
    "checkpoint-text2img-nature": {
      "file": "checkpoint-text2img-nature.workflow.json",
      "description": "Classic checkpoint-based txt2img nature workflow. Requires at least one visible local checkpoint in ComfyUI /object_info.",
      "comfyui_url_override": "http://127.0.0.1:8000",
      "default_inputs": {
        "extra_params": {
          "checkpoint_name": "your-checkpoint-name.safetensors",
          "steps": 24,
          "cfg": 7,
          "sampler_name": "dpmpp_2m",
          "scheduler": "karras",
          "filename_prefix": "nature-checkpoint-test"
        }
      },
      "mappings": {
        "positive_prompt": {
          "node_id": "2",
          "field_path": ["inputs", "text"]
        },
        "negative_prompt": {
          "node_id": "3",
          "field_path": ["inputs", "text"]
        },
        "seed": {
          "node_id": "5",
          "field_path": ["inputs", "seed"]
        },
        "width": {
          "node_id": "4",
          "field_path": ["inputs", "width"]
        },
        "height": {
          "node_id": "4",
          "field_path": ["inputs", "height"]
        },
        "extra_params": {
          "checkpoint_name": {
            "node_id": "1",
            "field_path": ["inputs", "ckpt_name"]
          },
          "steps": {
            "node_id": "5",
            "field_path": ["inputs", "steps"]
          },
          "cfg": {
            "node_id": "5",
            "field_path": ["inputs", "cfg"]
          },
          "sampler_name": {
            "node_id": "5",
            "field_path": ["inputs", "sampler_name"]
          },
          "scheduler": {
            "node_id": "5",
            "field_path": ["inputs", "scheduler"]
          },
          "filename_prefix": {
            "node_id": "7",
            "field_path": ["inputs", "filename_prefix"]
          }
        }
      }
    },
    "wan-i2v-pro": {
      "file": "wan-i2v-pro.workflow.json",
      "description": "WAN image-to-video placeholder. Replace with your exported working WAN I2V API prompt JSON. Defaults to ComfyUI Desktop-safe on :8000.",
      "comfyui_url_override": "http://127.0.0.1:8000",
      "default_inputs": {
        "extra_params": {
          "start_image": "robot-source.png",
          "duration_seconds": 6
        }
      },
      "mappings": {
        "positive_prompt": {
          "node_id": "MISSING",
          "field_path": ["inputs", "prompt"]
        }
      }
    }
  }
}

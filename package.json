{
  "name": "comfyui-mcp-runner",
  "version": "0.4.0",
  "description": "Minimal MCP server to run saved ComfyUI workflows locally",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "check": "tsc --noEmit",
    "test": "node --test tests/basic.test.mjs"
  },
  "keywords": [
    "mcp",
    "comfyui",
    "claude",
    "image-generation"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

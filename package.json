{
  "name": "comfyui-mcp-runner",
  "version": "1.0.0",
  "description": "Local-first MCP media runner for structured, reproducible code-rendered assets (SVG/HTML/Remotion) with optional local ComfyUI workflows.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "check": "tsc --noEmit",
    "test": "tsx --test tests/basic.test.mjs",
    "platform": "powershell -ExecutionPolicy Bypass -File scripts/start-platform.ps1",
    "platform:dev": "tsx src/index.ts",
    "media:demo": "tsx scripts/generate-media-demo.ts",
    "media:launch": "tsx scripts/generate-launch-assets.ts",
    "media:scenarios": "tsx scripts/generate-scenario-suite.ts",
    "media:treatment": "tsx scripts/generate-cinematic-treatment.ts",
    "media:check-launch": "tsx scripts/check-launch-assets.ts",
    "analyze:reference": "tsx scripts/analyze-reference-video.ts",
    "smoke:real": "tsx scripts/real-task-smoke.ts",
    "comfyui:health": "tsx scripts/comfyui-health.ts",
    "comfyui:run": "tsx scripts/comfyui-run-workflow.ts",
    "comfyui:start": "powershell -ExecutionPolicy Bypass -File scripts/start-comfyui-cpu.ps1",
    "comfyui:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-comfyui.ps1",
    "comfyui:desktop-safe:start": "powershell -ExecutionPolicy Bypass -File scripts/start-comfyui-desktop-safe.ps1",
    "comfyui:desktop-safe:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-comfyui-desktop-safe.ps1"
  },
  "keywords": [
    "mcp",
    "comfyui",
    "claude",
    "image-generation",
    "video-generation",
    "developer-tools"
  ],
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@modelcontextprotocol/sdk": "^1.12.3",
    "@remotion/bundler": "^4.0.462",
    "@remotion/renderer": "^4.0.462",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "remotion": "^4.0.462",
    "satori": "^0.12.1",
    "sharp": "^0.34.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
